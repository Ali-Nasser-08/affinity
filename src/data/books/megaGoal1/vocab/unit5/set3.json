            "arabicMeaning": "نسمة قوية مفاجئة / هبة رياح",
            "synonyms": [
                "blast of wind",
                "sudden breeze"
            ],
            "example": [
                {
                    "text": "An unusual "
                },
                {
                    "text": "gust",
                    "colorize": true
                },
                {
                    "text": " of wind caused the plane's engine to stall."
