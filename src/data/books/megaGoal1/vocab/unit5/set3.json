            "definition": [
                {
                    "text": "When an engine suddenly "
                },
                {
                    "text": "stops running",
                    "highlight": true
                },
                {
                    "text": " while the vehicle is "
                },
                {
                    "text": "still moving",
                    "highlight2": true
                }
