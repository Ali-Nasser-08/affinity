            "synonyms": [
                "narrow escape",
                "close call",
                "miraculous survival"
            ],
            "example": [
                {
                    "text": "Phil couldn't believe he had such a "
                },
                {
                    "text": "lucky escape",
                    "colorize": true
                },
                {
                    "text": " after his car exploded into flames."
