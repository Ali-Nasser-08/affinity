                }
            ],
            "arabicMeaning": "رائع / ممتع",
            "synonyms": [
                "awesome",
                "great",
                "sweet"
            ],
            "example": [
                {
                    "text": "He said I can drive the jeep. Isn't that "
                },
                {
                    "text": "cool",
                    "colorize": true
                },
                {
                    "text": "?"
                }
            ],
            "tips": "Very common informal adjective among young people. NOT about temperature here. Can also mean 'calm/confident' ('Stay cool under pressure')."
        },
        {
            "word": "Guess what?",
            "wordType": "phrase",
            "definition": [
                {
                    "text": "A conversational phrase used to "
                },
                {
                    "text": "introduce surprising or exciting news",
