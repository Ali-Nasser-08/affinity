        },
        {
            "word": "compliment",
            "wordType": "verb",
            "definition": [
                {
                    "text": "To say something "
                },
                {
                    "text": "kind or admiring",
                    "highlight": true
                },
                {
                    "text": " about someone to "
                },
                {
                    "text": "praise them",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "يُثني على / يمدح",
            "synonyms": [
                "praise",
                "say something nice about"
            ],
            "example": [
                {
                    "text": "My teacher "
                },
                {
                    "text": "complimented",
                    "colorize": true
                },
                {
                    "text": " me on my English improvement"
                }
            ],
            "tips": "NOT 'complement' (which means 'to complete'). Spelling trick: 'I' like receiving compliments! Both 'compliment' and 'praise' have positive meanings."
        },
        {
            "word": "promise",
            "wordType": "verb",
            "definition": [
                {
                    "text": "To make a "
                },
                {
                    "text": "serious commitment",
                    "highlight": true
                },
                {
                    "text": " that you will definitely "
                },
                {
                    "text": "do something",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "يعد / يُعاهد",
            "synonyms": [
                "vow",
                "assure",
                "guarantee"
            ],
            "example": [
                {
                    "text": "My father "
                },
                {
                    "text": "promised",
                    "colorize": true
                },
                {
                    "text": " to let me drive the jeep in the desert"
                }
            ],
            "tips": "Followed by 'to + verb': promise to help, promise to come. Breaking a promise = not keeping your word (considered rude/untrustworthy)."
        },
        {
