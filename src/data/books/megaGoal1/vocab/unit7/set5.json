            "arabicMeaning": "يُنظّم نفسه",
            "synonyms": [
                "get your act together",
                "prepare properly"
            ],
            "example": [
                {
                    "text": "After vacation, I need to "
                },
                {
                    "text": "get organized",
                    "colorize": true
                },
                {
                    "text": " with my notebooks and schedule"
                }
            ],
            "tips": "Very common expression at the start of school terms or new projects. Describes the process of becoming orderly."
        },
        {
            "word": "give my best",
            "wordType": "phrase",
            "definition": [
                {
                    "text": "A warm, polite way to "
                },
                {
                    "text": "send greetings",
                    "highlight": true
                },
                {
                    "text": " to someone's "
                },
                {
                    "text": "family or friends",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "أُبلِغ تحياتي",
            "synonyms": [
                "send my regards",
                "say hello to"
