        {
            "word": "get used to",
            "wordType": "phrasal verb phrase",
            "definition": [
                {
                    "text": "To gradually become "
                },
                {
                    "text": "comfortable or familiar",
                    "highlight": true
                },
                {
                    "text": " with a new "
                },
                {
                    "text": "situation or routine",
                    "highlight2": true
