            "wordType": "phrasal verb",
            "definition": [
                {
                    "text": "To finally start "
                },
                {
                    "text": "focusing seriously",
                    "highlight": true
                },
                {
                    "text": " on an important task after "
                },
                {
                    "text": "relaxing or delaying",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "يشرع في العمل بجد",
            "synonyms": [
                "start seriously",
                "settle down to"
