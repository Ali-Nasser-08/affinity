        },
        {
            "word": "P.S.",
            "wordType": "abbreviation",
            "definition": [
                {
                    "text": "Stands for 'postscript'; an "
                },
                {
                    "text": "extra message added",
                    "highlight": true
                },
                {
                    "text": " after the main body of a letter or email, usually "
                },
                {
                    "text": "after the signature",
