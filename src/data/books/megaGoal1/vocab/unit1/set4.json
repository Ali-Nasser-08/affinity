      ],
      "arabicMeaning": "ينسجم / يتأقلم اجتماعياً",
      "synonyms": [
        "blend in",
        "belong",
        "adapt socially"
      ],
      "example": [
        {
          "text": "When I moved to a new school, it took time to make friends and "
