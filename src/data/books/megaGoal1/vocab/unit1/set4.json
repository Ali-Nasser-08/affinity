        {
          "text": "You see",
          "colorize": true
        },
        {
          "text": ", I have a German passport because of my grandparents"
        }
      ],
      "tips": "'You see' helps introduce an explanation for something you just mentioned. It makes your reasoning clearer."
    },
    {
      "word": "by the way",
      "wordType": "phrase",
      "definition": [
        {
          "text": "Used to "
        },
        {
          "text": "introduce a new topic",
          "highlight": true
        },
        {
          "text": " or "
        },
        {
          "text": "mention something unrelated",
          "highlight2": true
        },
        {
          "text": " to the current conversation"
        }
      ],
      "arabicMeaning": "بالمناسبة / على فكرة",
      "synonyms": [
        "incidentally",
        "speaking of which",
        "anyway"
      ],
      "example": [
        {
          "text": "We should meet for coffee sometime. "
        },
        {
          "text": "By the way",
          "colorize": true
        },
        {
          "text": ", did you finish the project?"
        }
      ],
      "tips": "Use this when changing topics or adding something you just remembered. It's a smooth conversation transition."
    },
    {
      "word": "fit in",
      "wordType": "phrasal verb",
      "definition": [
        {
          "text": "To "
        },
        {
          "text": "be accepted",
          "highlight": true
        },
        {
          "text": " as part of a group; to feel "
        },
        {
          "text": "comfortable and belong",
          "highlight2": true
        },
        {
          "text": " in a social situation or environment"
