    {
      "word": "you see",
      "wordType": "phrase",
      "definition": [
        {
          "text": "Used to "
        },
        {
          "text": "explain or clarify",
          "highlight": true
        },
        {
          "text": " something, often providing "
        },
        {
          "text": "additional context or reasoning",
          "highlight2": true
        },
        {
          "text": " to help the listener understand"
