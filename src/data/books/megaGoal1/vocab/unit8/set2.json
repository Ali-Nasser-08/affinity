    "words": [
        {
            "word": "this guy / this person",
            "wordType": "phrase",
            "definition": [
                {
                    "text": "An informal way to refer to "
                },
                {
                    "text": "someone recently mentioned",
                    "highlight": true
                },
                {
                    "text": "; 'this guy' is casual (male or unspecified), "
                },
                {
                    "text": "'this person' is neutral/formal",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "هذا الشخص / هذا الرجل",
            "synonyms": [
                "this individual",
                "that person I mentioned"
            ],
            "example": [
                {
                    "text": "I saw an interview with "
                },
                {
                    "text": "this guy",
                    "colorize": true
                },
                {
                    "text": " who climbed Mount Everest without oxygen"
                }
            ],
            "tips": "'This guy' is very common in casual speech but avoid in formal writing. Use 'this person' when gender is unknown or for neutrality."
        },
        {
            "word": "to me",
            "wordType": "phrase",
            "definition": [
                {
                    "text": "Used to introduce a "
                },
                {
                    "text": "personal opinion or perspective",
                    "highlight": true
                },
                {
                    "text": "; emphasizes that the statement reflects "
                },
                {
                    "text": "your own viewpoint",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "في رأيي / بالنسبة لي",
            "synonyms": [
                "in my opinion",
                "from my perspective"
            ],
            "example": [
                {
                    "text": "That movie was boring—"
                },
                {
                    "text": "to me",
                    "colorize": true
                },
                {
                    "text": ", anyway. My friends loved it though"
                }
            ],
            "tips": "Often placed at the beginning or end of a sentence to soften opinions. Shows subjectivity: 'To me, pineapple belongs on pizza' = personal taste, not fact."
        },
        {
            "word": "You wouldn't know...?",
            "wordType": "rhetorical phrase",
            "definition": [
                {
                    "text": "A surprised or "
                },
                {
                    "text": "disbelieving question",
                    "highlight": true
                },
                {
                    "text": " implying the listener "
                },
                {
                    "text": "obviously would know",
                    "highlight2": true
                },
                {
                    "text": " the answer"
                }
            ],
            "arabicMeaning": "ألن تعرف...؟ (سؤال بلاغي يعبّر عن الدهشة)",
            "synonyms": [
                "Surely you'd know...",
                "You must know..."
            ],
            "example": [
                {
                    "text": "\"You wouldn't know",
                    "colorize": true
                },
                {
                    "text": " where the party is? You're the one who organized it!\""
                }
            ],
            "tips": "Rhetorical—speaker doesn't expect a real answer. Shows surprise that someone lacks obvious knowledge. Tone can be playful or slightly critical depending on context."
        },
        {
            "word": "have a ball",
            "wordType": "idiom",
            "definition": [
                {
                    "text": "To "
                },
                {
                    "text": "enjoy yourself immensely",
                    "highlight": true
                },
                {
                    "text": "; to "
                },
                {
                    "text": "have a wonderful, exciting time",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "يستمتع كثيرًا / يقضي وقتًا ممتعًا",
            "synonyms": [
                "have a blast",
                "have a great time",
                "enjoy oneself"
            ],
            "example": [
                {
                    "text": "We "
                },
                {
                    "text": "had a ball",
                    "colorize": true
                },
                {
                    "text": " at the amusement park—rode every roller coaster twice!"
                }
            ],
            "tips": "Very informal, cheerful idiom. 'Ball' here has nothing to do with sports—it comes from 'ball' meaning a formal dance party (where people had fun)."
        },
        {
            "word": "participate",
            "wordType": "verb",
            "definition": [
                {
                    "text": "To "
                },
                {
                    "text": "take part or join in",
                    "highlight": true
                },
                {
                    "text": " an activity, event, or "
                },
                {
                    "text": "program",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "يشارك",
            "synonyms": [
                "take part",
                "join in",
                "get involved"
            ],
            "example": [
                {
                    "text": "Over 200 students will "
                },
                {
                    "text": "participate",
                    "colorize": true
                },
                {
                    "text": " in the school's science fair next week"
                }
            ],
            "tips": "Always followed by 'in': participate in (something). More formal than 'join' or 'take part'. Noun form: participation."
        },
        {
            "word": "divide",
            "wordType": "verb",
            "definition": [
                {
                    "text": "To "
