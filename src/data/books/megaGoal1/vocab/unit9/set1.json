            "example": [
                {
                    "text": "My backpack strap got caught in the bus door and came back completely "
                },
                {
                    "text": "torn",
                    "colorize": true
                },
                {
                    "text": ""
                }
            ],
            "tips": "Different from 'hole' (missing material) – torn implies edges were pulled apart. Often repairable by sewing unless severely damaged."
        },
        {
