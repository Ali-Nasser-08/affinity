    "words": [
        {
            "word": "leaky pipe",
            "wordType": "noun phrase",
            "definition": [
                {
                    "text": "A pipe that allows water to "
                },
                {
                    "text": "escape through small holes",
                    "highlight": true
                },
                {
                    "text": " or "
                },
                {
                    "text": "cracks, causing drips or flooding",
                    "highlight2": true
                }
