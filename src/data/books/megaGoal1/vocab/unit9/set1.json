        },
        {
            "word": "stain",
            "wordType": "noun",
            "definition": [
                {
                    "text": "A "
                },
                {
                    "text": "discolored mark",
                    "highlight": true
                },
                {
                    "text": " left on fabric, carpet, or surfaces by "
                },
                {
                    "text": "spilled liquids or dirt",
