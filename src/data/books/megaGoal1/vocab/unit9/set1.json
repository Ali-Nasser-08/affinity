                },
                {
                    "text": " after months of use, and now it swings open by itself"
                }
            ],
            "tips": "Common with screws, handles, floorboards, and furniture joints. Usually fixed by tightening screws or replacing worn parts."
        },
        {
            "word": "torn",
            "wordType": "adjective",
            "definition": [
                {
                    "text": "Ripped or "
                },
                {
                    "text": "split apart",
                    "highlight": true
                },
                {
                    "text": " with a visible "
                },
                {
                    "text": "opening or hole",
                    "highlight2": true
                },
                {
                    "text": " in fabric or paper"
                }
            ],
            "arabicMeaning": "ممزّق",
            "synonyms": [
                "ripped",
                "shredded",
                "tattered"
