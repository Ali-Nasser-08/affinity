    "words": [
        {
            "word": "Murphy's Law",
            "wordType": "noun phrase",
            "definition": [
                {
                    "text": "The humorous belief that "
                },
                {
                    "text": "if something can go wrong",
                    "highlight": true
                },
                {
                    "text": ", it "
                },
                {
                    "text": "probably will",
                    "highlight2": true
                },
                {
                    "text": " — especially at the worst possible moment"
                }
            ],
            "arabicMeaning": "قانون ميرفي",
            "synonyms": [
                "Sod's Law (British)",
                "the principle of worst-case scenarios"
            ],
            "example": [
                {
                    "text": "I wore my white shirt on the day the coffee machine started leaking—classic "
                },
                {
                    "text": "Murphy's Law",
                    "colorize": true
                },
                {
                    "text": " in action"
                }
            ],
            "tips": "Named after engineer Edward Murphy (1949). Not a real scientific law—more a cynical observation about everyday frustrations. Often quoted humorously when things go wrong."
        },
        {
