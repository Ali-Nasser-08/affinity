        {
            "word": "key ring",
            "wordType": "noun",
            "definition": [
                {
                    "text": "A small metal ring or chain used to "
                },
                {
                    "text": "hold multiple keys together",
                    "highlight": true
                },
                {
                    "text": " so they don't get "
                },
                {
                    "text": "lost separately",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "سلسلة مفاتيح",
            "synonyms": [
                "keychain",
                "key holder"
            ],
            "example": [
                {
                    "text": "I dropped my "
                },
                {
                    "text": "key ring",
                    "colorize": true
                },
                {
                    "text": " in a puddle and spent ten minutes fishing it out with a stick"
                }
            ],
            "tips": "American English: 'key ring' (two words) or 'keychain' (one word). British English often says 'keyring' (one word). Not the same as 'key fob' (electronic car key)."
        },
        {
            "word": "selective memory",
            "wordType": "noun phrase",
            "definition": [
                {
                    "text": "The tendency to "
                },
                {
                    "text": "remember certain events",
                    "highlight": true
                },
                {
                    "text": " (usually negative or positive ones) while "
                },
                {
                    "text": "forgetting others",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "ذاكرة انتقائية",
            "synonyms": [
                "biased recall",
                "convenient forgetting"
            ],
            "example": [
                {
                    "text": "He has such "
                },
                {
                    "text": "selective memory",
                    "colorize": true
                },
                {
                    "text": " — he remembers every time I was late but forgets all the times he canceled plans"
                }
            ],
            "tips": "Psychological concept explaining why we recall frustrating events more vividly than smooth ones. Not intentional deception—just how human memory works."
        },
        {
            "word": "probability",
            "wordType": "noun",
            "definition": [
                {
                    "text": "The "
                },
                {
                    "text": "likelihood or chance",
                    "highlight": true
                },
                {
                    "text": " that something will happen, often expressed as a "
                },
                {
                    "text": "percentage or fraction",
                    "highlight2": true
                }
