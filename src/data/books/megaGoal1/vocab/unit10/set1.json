{
    "unit": "Mega Goal 1 - Unit 10: I Wonder What Happened",
    "type": "reading",
    "setTitle": "Reading: Meteorite Hits House",
    "words": [
        {
            "word": "must have",
            "wordType": "phrase",
            "definition": [
                {
                    "text": "Used when you feel "
                },
                {
                    "text": "certain about something in the past",
                    "highlight": true
                },
                {
                    "text": " based on "
                },
                {
                    "text": "evidence or logic",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "لابد أنه / لا بد أنه",
            "synonyms": [
                "almost certainly",
                "definitely did"
            ],
            "example": [
                {
                    "text": "The streets are wet and people are carrying umbrellas. It "
                },
                {
                    "text": "must have",
                    "colorize": true
                },
                {
                    "text": " rained earlier"
                }
            ],
            "tips": "Shows strong confidence about a past event. Not a guess—you have reasons to believe it happened."
        },
        {
            "word": "can't be",
            "wordType": "phrase",
            "definition": [
                {
                    "text": "Used to say something is "
                },
                {
                    "text": "impossible or definitely not true",
                    "highlight": true
                },
                {
                    "text": " in the present "
                },
                {
                    "text": "situation",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "لا يمكن أن يكون",
            "synonyms": [
                "definitely not",
                "impossible"
            ],
            "example": [
                {
                    "text": "That tiny puppy "
                },
                {
                    "text": "can't be",
                    "colorize": true
                },
                {
                    "text": " the one who ate the whole loaf of bread!"
                }
            ],
            "tips": "Expresses strong disbelief. Opposite of 'must be' (which shows certainty that something IS true)."
        },
        {
            "word": "might have",
            "wordType": "phrase",
            "definition": [
                {
                    "text": "Used to suggest a "
                },
                {
                    "text": "possible explanation",
                    "highlight": true
                },
                {
                    "text": " for something that happened in the "
                },
                {
                    "text": "past—but you're not sure",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "ربما / قد يكون",
            "synonyms": [
                "maybe",
                "possibly"
            ],
            "example": [
                {
                    "text": "I can't find my keys. I "
                },
                {
                    "text": "might have",
                    "colorize": true
                },
                {
                    "text": " left them at the office"
                }
            ],
            "tips": "Shows uncertainty. Softer than 'must have'. 'Might have' and 'may have' mean the same thing here."
        },
        {
            "word": "could have",
            "wordType": "phrase",
            "definition": [
                {
                    "text": "Used to describe something that was "
                },
                {
                    "text": "possible in the past",
                    "highlight": true
                },
                {
                    "text": " but you don't know if it actually "
                },
                {
                    "text": "happened",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "كان من الممكن أن",
            "synonyms": [
                "possibly",
                "maybe"
            ],
            "example": [
                {
                    "text": "The lights went out suddenly. A fuse "
                },
                {
                    "text": "could have",
                    "colorize": true
                },
                {
                    "text": " blown"
                }
            ],
            "tips": "Similar to 'might have' but sometimes suggests a slightly more realistic possibility. Not the same as 'could have' for regrets ('I could have studied harder')."
        },
        {
            "word": "meteorite",
