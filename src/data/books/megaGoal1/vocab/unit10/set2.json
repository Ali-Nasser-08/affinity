            "example": [
                {
                    "text": "My "
                },
                {
                    "text": "alarm clock",
                    "colorize": true
                },
                {
                    "text": " didn't ring this morning because the batteries died overnight"
                }
            ],
            "tips": "Many people now use phone alarms instead of separate alarm clocks. 'Set the alarm' = choose the wake-up time. 'Snooze button' = delays alarm for a few more minutes."
        },
        {
            "word": "extinct",
            "wordType": "adjective",
            "definition": [
                {
                    "text": "No longer existing; when every member of a species has "
                },
                {
                    "text": "died out completely",
                    "highlight": true
                },
