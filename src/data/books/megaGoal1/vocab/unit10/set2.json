            "arabicMeaning": "منقرض",
            "synonyms": [
                "died out",
                "no longer existing"
            ],
            "example": [
                {
                    "text": "The dodo bird has been "
                },
                {
                    "text": "extinct",
                    "colorize": true
                },
                {
                    "text": " since the 17th century after sailors hunted them to extinction"
                }
            ],
            "tips": "Applies to animals/plants that no longer exist anywhere. Different from 'endangered' (still exists but in danger of extinction). Verb form: go extinct / become extinct."
        },
        {
            "word": "break into",
            "wordType": "phrasal verb",
            "definition": [
                {
                    "text": "To enter a building "
                },
                {
                    "text": "illegally and by force",
                    "highlight": true
                },
                {
                    "text": " — usually by damaging a door, window, or "
                },
                {
                    "text": "lock",
                    "highlight2": true
                }
