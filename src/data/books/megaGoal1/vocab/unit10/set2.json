                },
                {
                    "text": " at the mountain summit just as the sun was rising"
                }
            ],
            "tips": "Never followed by 'to' with places: 'arrive home' ✅ NOT 'arrive to home' ❌. Exception: 'arrive at/in' + specific location ('arrive at the station', 'arrive in Paris')."
        },
        {
            "word": "already",
            "wordType": "adverb",
            "definition": [
                {
                    "text": "Before the expected time; something that has "
                },
                {
                    "text": "happened sooner",
                    "highlight": true
                },
                {
                    "text": " than "
                },
                {
                    "text": "anticipated",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "بالفعل / سبق",
            "synonyms": [
                "by now",
                "before this time"
            ],
            "example": [
                {
                    "text": "Don't worry about dinner—I've "
                },
                {
                    "text": "already",
