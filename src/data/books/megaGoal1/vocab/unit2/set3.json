      "example": [
        {
          "text": "The "
        },
        {
          "text": "archaeologist",
          "colorize": true
        },
        {
          "text": " discovered ancient pottery that was over 3,000 years old"
        }
      ],
      "tips": "The field is 'archaeology'. Archaeologists dig up ruins and artifacts to learn about ancient cultures."
    },
    {
