            "arabicMeaning": "يترك رسالة",
            "synonyms": [
                "record a message",
                "drop a note"
            ],
            "example": [
                {
                    "text": "The receptionist said the doctor was with a patient and asked if I'd like to "
                },
                {
                    "text": "leave a message",
                    "colorize": true
                },
                {
                    "text": " for a callback"
                }
            ],
            "tips": "Common phone etiquette phrase. Often preceded by 'Would you like to...' or 'Can I...'. Not the same as 'take a message' (receiving/recording someone else's message)."
        },
        {
