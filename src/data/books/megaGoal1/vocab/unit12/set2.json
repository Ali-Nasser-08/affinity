        {
            "word": "leave a message",
            "wordType": "phrase",
            "definition": [
                {
                    "text": "To record or write information for someone to receive later when they are "
                },
                {
                    "text": "not available",
                    "highlight": true
                },
                {
                    "text": " at the moment of "
                },
                {
