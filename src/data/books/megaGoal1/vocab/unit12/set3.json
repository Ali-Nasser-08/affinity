            "wordType": "noun phrase",
            "definition": [
                {
                    "text": "A business that helps people plan and book trips by arranging "
                },
                {
                    "text": "transportation, accommodations",
                    "highlight": true
                },
                {
                    "text": ", and "
                },
                {
                    "text": "tours",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "وكالة سفر",
            "synonyms": [
                "travel bureau",
                "tour operator"
            ],
            "example": [
                {
                    "text": "The "
                },
                {
                    "text": "travel agency",
                    "colorize": true
                },
                {
                    "text": " found us a package deal that included flights, hotel, and guided tours for 30% less than booking separately"
                }
            ],
            "tips": "Traditional brick-and-mortar businesses, though many now operate online. Different from 'travel agent' (the person) vs. 'travel agency' (the company)."
        },
        {
            "word": "contest",
            "wordType": "noun",
            "definition": [
                {
                    "text": "An event where people compete to win a prize based on skill, luck, or judgment; a "
                },
                {
                    "text": "competition",
                    "highlight": true
                },
                {
                    "text": " with "
                },
                {
                    "text": "official rules and winners",
                    "highlight2": true
                }
            ],
            "arabicMeaning": "مسابقة",
            "synonyms": [
                "competition",
                "sweepstakes (luck-based)",
                "giveaway"
            ],
            "example": [
                {
                    "text": "She entered a baking "
                },
                {
                    "text": "contest",
