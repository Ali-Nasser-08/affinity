                },
                {
                    "text": "; asking for confirmation"
                }
            ],
            "arabicMeaning": "هل تقصد؟",
            "synonyms": [
                "Do you mean",
                "Are you saying",
                "So you're saying"
            ],
            "example": [
                {
                    "text": "\"I think we should postpone the meeting.\" \""
                },
                {
                    "text": "You mean",
                    "colorize": true
                },
                {
                    "text": " cancel it completely, or just move it to next week?\""
                }
