            },
            {
              "text": " you "
            },
            {
              "text": "been reading",
              "colorize": true
            },
            {
              "text": " that book?"
            },
            {
              "text": "س: منذ متى وأنت "
            },
            {
              "text": "تقرأ",
              "colorize": true
            },
            {
              "text": " ذلك الكتاب؟"
            }
