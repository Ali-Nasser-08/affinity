            {
              "text": "استخدم "
            },
            {
              "text": "منذ",
              "colorize": true
            },
            {
              "text": " لـ"
            },
            {
              "text": "نقطة زمنية محددة",
              "colorize2": true
            },
            {
              "text": " (متى بدأ)"
            }
          ]
        },
        {
          "id": "card-19",
          "type": "example",
          "content": [
            {
              "text": "I have been studying "
            },
            {
              "text": "since",
              "colorize": true
            },
            {
              "text": " "
