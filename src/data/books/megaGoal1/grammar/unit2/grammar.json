        {
          "id": "card-17",
          "content": [
            {
              "text": "This form often uses "
            },
            {
              "text": "since",
              "colorize": true
            },
            {
              "text": " and "
            },
            {
              "text": "for",
              "colorize": true
            },
            {
              "text": " to show "
            },
            {
              "text": "how long",
              "colorize2": true
            },
            {
              "text": " the action has been happening"
            },
            {
              "text": "الحاضر التام المستمر غالباً يستخدم "
            },
            {
              "text": "منذ",
              "colorize": true
            },
            {
              "text": " و"
            },
            {
              "text": "لمدة",
              "colorize": true
            },
            {
              "text": " لإظهار "
            },
            {
              "text": "طول المدة الزمنية",
              "colorize2": true
            },
            {
              "text": " التي يحدث فيها الفعل"
            }
