  "clusters": [
    {
      "clusterId": "cluster-1",
      "title": "Present Perfect Progressive vs Simple",
      "cards": [
        {
          "id": "card-1",
          "content": [
            {
              "text": "Present Perfect: Continuous and Simple Forms",
              "highlight": true
            },
            {
              "text": "الحاضر التام: المستمر والبسيط"
            }
          ]
        },
        {
          "id": "card-2",
          "content": [
            {
              "text": "Both forms describe actions that "
            },
            {
              "text": "started in the past",
              "colorize2": true
            },
            {
              "text": " and "
            },
            {
              "text": "continue to now",
              "colorize2": true
            },
            {
              "text": "كلا الزمنين يتحدثان عن موقف "
            },
            {
              "text": "بدأ في الماضي",
              "colorize2": true
            },
            {
              "text": " و "
            },
            {
              "text": "يستمر حتى الحاضر ",
              "colorize2": true
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-2",
      "title": "Present Perfect Progressive",
      "cards": [
        {
          "id": "card-3",
          "content": [
            {
              "text": "The Continuous Present Perfect",
              "highlight": true
            },
            {
              "text": "الحاضر التام المستمر"
            }
          ]
        },
        {
          "id": "card-3b",
          "type": "structure",
          "content": [
            {
              "text": "Subject",
              "badge": true,
              "translation": "الفاعل"
            },
            {
              "text": " + "
            },
            {
              "text": "has/have",
              "badge2": true,
              "translation": "مساعد"
            },
            {
              "text": " + "
            },
            {
              "text": "been",
              "badge3": true,
              "translation": "كان"
            },
            {
              "text": " + "
            },
            {
              "text": "Verb-ing",
              "badge3": true,
              "translation": "فعل + ing"
            }
          ],
          "wide": true
        },
        {
          "id": "card-3c",
          "type": "structure",
          "content": [
            {
              "text": "Use "
            },
            {
              "text": "has",
              "badge": true
            },
            {
              "text": " with "
            },
            {
              "text": "he/she/it",
              "colorize2": true
            },
            {
              "text": ", "
            },
            {
              "text": "have",
              "badge2": true
            },
            {
              "text": " with "
            },
            {
              "text": "I/you/we/they",
              "colorize2": true
            }
          ],
          "wide": true
        },
        {
          "id": "card-4",
          "content": [
            {
              "text": "Use this for actions that are "
            },
            {
              "text": "happening right now",
              "colorize2": true
            },
            {
              "text": " and "
            },
            {
              "text": "will likely continue",
              "colorize2": true
            },
            {
              "text": "استخدمه للفعل الذي "
            },
            {
              "text": "يحدث الآن",
              "colorize2": true
            },
            {
              "text": " و"
            },
            {
              "text": "سيستمر على الأرجح",
              "colorize2": true
            }
          ]
        },
        {
          "id": "card-5",
          "type": "example",
          "content": [
            {
              "text": "Sarah "
            },
            {
              "text": "has been reading",
              "colorize": true
            },
            {
              "text": " a book "
            },
            {
              "text": "for two hours",
              "colorize3": true
            },
            {
              "text": "حنان "
            },
            {
              "text": "تقرأ",
