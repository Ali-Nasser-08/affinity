    },
    {
      "clusterId": "cluster-4",
      "title": "Time Expressions: Since and For",
      "cards": [
        {
          "id": "card-16",
          "content": [
            {
              "text": "Important Note:",
              "highlight": true
            },
            {
              "text": " Time Words with the Continuous Form"
            },
            {
              "text": "ملاحظة مهمة: التعبيرات الزمنية مع الحاضر التام المستمر"
