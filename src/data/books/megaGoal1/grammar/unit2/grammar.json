            {
              "text": "For",
              "colorize": true
            },
            {
              "text": " لـ"
            },
            {
              "text": "فترة زمنية",
              "colorize2": true
            },
            {
              "text": " (المدة)"
            }
          ]
        },
        {
          "id": "card-22",
          "type": "example",
          "content": [
            {
