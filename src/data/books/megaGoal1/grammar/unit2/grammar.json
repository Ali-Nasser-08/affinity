            },
            {
              "text": " كتابًا "
            },
            {
              "text": "منذ ساعتين",
              "colorize3": true
            }
          ]
        },
        {
          "id": "card-6",
          "type": "example",
          "content": [
            {
              "text": "Q: How long "
            },
            {
              "text": "have",
