            },
            {
              "text": " كرة القدم "
            },
            {
              "text": "منذ أن كان في العاشرة",
              "colorize3": true
            }
          ]
        },
        {
          "id": "card-8",
          "type": "example",
          "content": [
            {
              "text": "Q: How long "
            },
            {
              "text": "have",
              "colorize2": true
            },
            {
              "text": " you "
            },
            {
              "text": "been playing",
              "colorize": true
            },
            {
              "text": " football?"
            },
            {
              "text": "س: منذ متى وأنت "
            },
            {
              "text": "تلعب",
              "colorize": true
            },
            {
              "text": " كرة القدم؟"
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-3",
      "title": "Present Perfect Simple",
      "cards": [
        {
          "id": "card-9",
          "content": [
            {
              "text": "The Simple Present Perfect",
              "highlight": true
            },
            {
              "text": "الحاضر التام البسيط"
            }
          ]
        },
        {
          "id": "card-9b",
          "type": "structure",
          "content": [
            {
              "text": "Subject",
              "badge": true,
              "translation": "الفاعل"
            },
            {
              "text": " + "
            },
            {
              "text": "has/have",
              "badge2": true,
              "translation": "مساعد"
            },
            {
              "text": " + "
            },
            {
              "text": "Past Participle",
              "badge3": true,
              "translation": "التصريف الثالث"
            }
          ],
          "wide": true
        },
        {
          "id": "card-10",
          "content": [
            {
              "text": "Use this to talk about "
            },
            {
              "text": "how many times",
              "colorize2": true
            },
            {
              "text": " or "
            },
            {
              "text": "how long",
              "colorize2": true
            },
            {
              "text": " something has happened by now"
            },
            {
              "text": "استخدمه للتحدث عن "
            },
            {
              "text": "عدد المرات",
              "colorize2": true
            },
            {
              "text": " أو "
            },
            {
              "text": "المدة",
              "colorize2": true
            },
            {
              "text": " التي تم فيها عمل شيء حتى هذه النقطة"
            }
          ]
        },
        {
          "id": "card-11",
          "content": [
            {
              "text": "The action "
            },
            {
              "text": "isn't happening now",
              "colorize2": true
            },
            {
              "text": " and "
