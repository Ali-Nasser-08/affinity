            {
              "text": "have",
              "colorize2": true
            },
            {
              "text": " you "
            },
            {
              "text": "read",
              "colorize": true
            },
            {
              "text": "?"
            },
            {
              "text": "س: كم صفحة "
            },
            {
              "text": "قرأت",
              "colorize": true
            },
            {
              "text": "؟"
            }
