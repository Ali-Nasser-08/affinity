            },
            {
              "text": " you "
            },
            {
              "text": "played",
              "colorize": true
            },
            {
              "text": " for?"
            },
            {
              "text": "س: لكم فريق "
            },
            {
              "text": "لعبت",
              "colorize": true
            },
            {
              "text": "؟"
            }
