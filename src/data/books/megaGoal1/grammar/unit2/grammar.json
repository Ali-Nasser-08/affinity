            {
              "text": " for "
            },
            {
              "text": "three different teams",
              "colorize3": true
            },
            {
              "text": "هو "
            },
            {
              "text": "لعب",
              "colorize": true
            },
            {
              "text": " لـ"
            },
            {
              "text": "ثلاثة فرق مختلفة",
              "colorize3": true
