                    ]
                },
                {
                    "id": "card-33",
                    "type": "example",
                    "content": [
                        {
                            "text": "Customer: ",
                            "colorize": true
                        },
                        {
                            "text": "How much is this leather wallet?"
                        },
                        {
                            "text": "الزبون: ",
                            "colorize": true
                        },
                        {
                            "text": "بكم هذا المحفظة الجلدية؟"
                        }
                    ]
                },
                {
                    "id": "card-34",
                    "type": "example",
                    "content": [
                        {
                            "text": "Salesperson: ",
                            "colorize": true
                        },
                        {
                            "text": "It's 280 riyals. We're offering a 25% discount today."
                        },
                        {
                            "text": "البائع: ",
                            "colorize": true
                        },
                        {
                            "text": "بسعر 280 ريالاً. نقدم خصم 25% اليوم."
                        }
                    ]
                },
                {
                    "id": "card-35",
                    "type": "example",
                    "content": [
                        {
                            "text": "Customer: ",
                            "colorize": true
                        },
                        {
                            "text": "Perfect! I'll take it. I'd like to pay by credit card."
                        },
                        {
                            "text": "الزبون: ",
                            "colorize": true
                        },
                        {
                            "text": "ممتاز! سأشتريه. أود الدفع ببطاقة ائتمان."
                        }
                    ]
                },
                {
                    "id": "card-36",
                    "type": "example",
                    "content": [
                        {
                            "text": "Salesperson: ",
                            "colorize": true
                        },
                        {
                            "text": "Excellent choice. Would you like a gift bag?"
                        },
                        {
                            "text": "البائع: ",
                            "colorize": true
