                    ]
                },
                {
                    "id": "card-27",
                    "content": [
                        {
                            "text": "Common shopping topics include: "
                        },
                        {
                            "text": "items",
                            "colorize": true
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "materials",
                            "colorize": true
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "sizes",
                            "colorize": true
                        },
                        {
                            "text": ", and "
                        },
                        {
                            "text": "prices",
                            "colorize": true
                        },
                        {
                            "text": "."
                        },
                        {
                            "text": "مواضيع التسوق الشائعة تشمل: "
                        },
                        {
                            "text": "المنتجات",
                            "colorize": true
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "المواد",
                            "colorize": true
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "المقاسات",
