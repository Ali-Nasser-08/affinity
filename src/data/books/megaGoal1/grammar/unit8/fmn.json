                        },
                        {
                            "text": "، و"
                        },
                        {
                            "text": "الأسعار",
                            "colorize": true
                        },
                        {
                            "text": "."
                        }
                    ]
                },
                {
                    "id": "card-28",
                    "wide": true,
                    "type": "structure",
                    "content": [
                        {
                            "text": "Item",
                            "badge": true,
                            "translation": "منتج"
                        },
                        {
                            "text": " → "
