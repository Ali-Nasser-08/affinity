        {
            "clusterId": "cluster-1",
            "title": "Reported Speech - Overview",
            "cards": [
                {
                    "id": "card-1",
                    "content": [
                        {
                            "text": "Reported Speech",
                            "highlight": true
                        },
                        {
                            "text": "الكلام المنقول"
                        }
                    ]
                },
                {
                    "id": "card-2",
                    "content": [
                        {
                            "text": "When reporting what someone said, the "
                        },
                        {
                            "text": "verb tense usually shifts back",
                            "colorize2": true
                        },
                        {
                            "text": "عند نقل ما قاله شخص ما، "
                        },
                        {
                            "text": "زمن الفعل عادة يتحول للخلف",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-3",
                    "content": [
                        {
                            "text": "Note:",
                            "highlight": true
                        },
                        {
                            "text": " The word "
                        },
                        {
                            "text": "that",
                            "colorize": true
                        },
                        {
                            "text": " after 'said' is optional and can be dropped"
                        },
                        {
                            "text": "ملاحظة: كلمة "
                        },
                        {
                            "text": "that",
                            "colorize": true
                        },
                        {
                            "text": " بعد 'said' اختيارية ويمكن حذفها"
                        }
                    ]
                }
            ]
        },
