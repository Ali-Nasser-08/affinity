            "cards": [
                {
                    "id": "card-1",
                    "content": [
                        {
                            "text": "Environment and Natural Disasters",
                            "highlight": true
                        },
                        {
                            "text": "البيئة والكوارث الطبيعية"
                        }
                    ]
                },
                {
                    "id": "card-2",
                    "content": [
                        {
                            "text": "Environmental Issues:",
                            "highlight": true
                        },
                        {
                            "text": " climate change, soil loss, air contamination, water contamination, excessive fishing, forest clearing"
                        },
                        {
                            "text": "القضايا البيئية: تغير المناخ، فقدان التربة، تلوث الهواء، تلوث الماء، الصيد الجائر، إزالة الغابات"
                        }
                    ]
                },
                {
                    "id": "card-3",
                    "content": [
                        {
                            "text": "Natural Disasters:",
                            "highlight": true
                        },
                        {
                            "text": " flooding, earthquakes, tornadoes, tsunamis, volcanic eruptions, wildfires"
                        },
                        {
                            "text": "الكوارث الطبيعية: الفيضانات، الزلازل، الأعاصير، أمواج تسونامي، الانفجارات البركانية، حرائق الغابات"
                        }
                    ]
                },
                {
                    "id": "card-4",
                    "content": [
                        {
                            "text": "Action Words:",
                            "highlight": true
                        },
                        {
                            "text": " harm, endanger, save, safeguard, strike, investigate"
                        },
                        {
                            "text": "أفعال العمل: يضر، يعرض للخطر، ينقذ، يحمي، يضرب، يبحث"
                        }
                    ]
                },
                {
                    "id": "card-5",
                    "type": "example",
                    "content": [
                        {
                            "text": "The hurricane "
                        },
                        {
                            "text": "damaged",
                            "colorize": true
                        },
                        {
                            "text": " many buildings"
                        },
                        {
                            "text": "الإعصار "
                        },
                        {
                            "text": "ألحق الضرر",
                            "colorize": true
                        },
                        {
                            "text": " بالعديد من المباني"
                        }
                    ]
                },
                {
                    "id": "card-6",
                    "type": "example",
                    "content": [
                        {
                            "text": "Scientists are "
                        },
                        {
                            "text": "researching",
                            "colorize": true
                        },
