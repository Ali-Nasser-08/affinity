        },
        {
            "clusterId": "cluster-5",
            "title": "Plural Nouns",
            "cards": [
                {
                    "id": "card-28",
                    "content": [
                        {
                            "text": "Plural Nouns",
                            "highlight": true
                        },
                        {
                            "text": "جمع الأسماء"
                        }
                    ]
                },
                {
                    "id": "card-29",
                    "content": [
                        {
                            "text": "Most nouns add "
                        },
                        {
                            "text": "-s",
                            "colorize": true
                        },
                        {
                            "text": " for plural"
                        },
                        {
                            "text": "تضيف معظم الأسماء "
                        },
                        {
                            "text": "-s",
                            "colorize": true
                        },
                        {
                            "text": " للجمع"
                        }
                    ]
                },
                {
                    "id": "card-30",
                    "type": "example",
                    "content": [
                        {
                            "text": "stamp → ",
                            "colorize": true
                        },
                        {
                            "text": "stamps",
                            "colorize2": true
                        },
                        {
                            "text": "طابع → ",
                            "colorize": true
                        },
                        {
                            "text": "طوابع",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-31",
                    "content": [
                        {
                            "text": "Nouns ending in -s, -sh, -ch, -x, or -z add "
                        },
                        {
                            "text": "-es",
                            "colorize": true
                        },
                        {
                            "text": "الأسـماء المنتهية بـ -s, -sh, -ch, -x, أو -z تضيف "
                        },
                        {
                            "text": "-es",
                            "colorize": true
                        }
                    ]
                },
                {
                    "id": "card-32",
                    "type": "example",
                    "content": [
                        {
                            "text": "box → ",
                            "colorize": true
                        },
                        {
                            "text": "boxes",
                            "colorize2": true
                        },
                        {
                            "text": "صندوق → ",
                            "colorize": true
                        },
                        {
                            "text": "صناديق",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-33",
                    "content": [
                        {
                            "text": "Nouns ending in consonant + -y change y to i and add "
                        },
                        {
                            "text": "-es",
                            "colorize": true
                        },
                        {
                            "text": "الأسـماء المنتهية بساكن + -y تغيّر y إلى i وتضيف "
                        },
                        {
                            "text": "-es",
                            "colorize": true
                        }
                    ]
                },
                {
                    "id": "card-34",
                    "type": "example",
                    "content": [
                        {
                            "text": "reply → ",
                            "colorize": true
                        },
                        {
                            "text": "replies",
                            "colorize2": true
                        },
                        {
                            "text": "رد → ",
                            "colorize": true
                        },
                        {
                            "text": "ردود",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-35",
                    "content": [
                        {
                            "text": "Exception: Nouns with vowel + -y just add "
                        },
                        {
                            "text": "-s",
                            "colorize": true
                        },
                        {
                            "text": "استثناء: الأسماء بحرف علة + -y تضيف فقط "
                        },
                        {
                            "text": "-s",
                            "colorize": true
                        }
                    ]
                },
                {
                    "id": "card-36",
                    "type": "example",
                    "content": [
                        {
                            "text": "key → ",
                            "colorize": true
                        },
                        {
                            "text": "keys",
                            "colorize2": true
                        },
                        {
                            "text": "مفتاح → ",
                            "colorize": true
                        },
                        {
                            "text": "مفاتيح",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-37",
                    "content": [
                        {
                            "text": "Some nouns ending in -f or -fe change to "
                        },
                        {
                            "text": "-ves",
                            "colorize": true
                        },
                        {
                            "text": "بعض الأسماء المنتهية بـ -f أو -fe تغيّر إلى "
                        },
                        {
                            "text": "-ves",
                            "colorize": true
                        }
                    ]
                },
                {
                    "id": "card-38",
                    "type": "example",
                    "content": [
                        {
                            "text": "leaf → ",
                            "colorize": true
                        },
                        {
                            "text": "leaves",
                            "colorize2": true
                        },
                        {
                            "text": "ورقة → ",
                            "colorize": true
                        },
                        {
                            "text": "أوراق",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-39",
                    "content": [
                        {
                            "text": "Irregular plurals",
                            "highlight": true
                        },
                        {
                            "text": " follow no pattern and must be memorized"
                        },
                        {
                            "text": "الجمع غير المنتظم",
                            "highlight": true
                        },
                        {
                            "text": " لا يتبع نمطاً ويجب حفظه"
                        }
                    ]
                },
                {
                    "id": "card-40",
                    "type": "example",
                    "content": [
                        {
                            "text": "man → ",
                            "colorize": true
                        },
                        {
                            "text": "men",
                            "colorize2": true
                        },
                        {
                            "text": "رجل → ",
                            "colorize": true
                        },
                        {
                            "text": "رجال",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-41",
                    "type": "example",
                    "content": [
                        {
                            "text": "child → ",
                            "colorize": true
                        },
                        {
                            "text": "children",
                            "colorize2": true
                        },
                        {
                            "text": "طفل → ",
                            "colorize": true
                        },
                        {
                            "text": "أطفال",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-42",
                    "type": "example",
                    "content": [
                        {
                            "text": "tooth → ",
                            "colorize": true
                        },
                        {
                            "text": "teeth",
                            "colorize2": true
                        },
                        {
                            "text": "سن → ",
                            "colorize": true
                        },
                        {
                            "text": "أسنان",
                            "colorize2": true
                        }
                    ]
                }
            ]
        },
        {
            "clusterId": "cluster-6",
            "title": "Definite Article: The",
            "cards": [
                {
                    "id": "card-43",
