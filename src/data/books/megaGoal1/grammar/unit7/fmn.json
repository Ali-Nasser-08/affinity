        },
        {
            "clusterId": "cluster-2",
            "title": "Used To versus Would",
            "cards": [
                {
                    "id": "card-9",
                    "content": [
                        {
                            "text": "Used To",
                            "highlight": true
                        },
                        {
                            "text": " versus ",
                            "highlight": true
                        },
                        {
                            "text": "Would",
                            "highlight": true
                        },
                        {
                            "text": "Used To مقابل Would"
                        }
                    ]
                },
                {
                    "id": "card-10",
                    "content": [
                        {
                            "text": "Both describe repeated past actions, but "
                        },
                        {
                            "text": "would cannot describe states",
                            "colorize2": true
                        },
                        {
                            "text": "كلاهما يصف الأفعال المتكررة في الماضي، لكن "
                        },
                        {
                            "text": "لا يمكن لـ would وصف الحالات",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-11",
                    "type": "example",
                    "content": [
                        {
                            "text": "✓ Every morning the postman "
                        },
                        {
                            "text": "would deliver",
                            "colorize": true
                        },
                        {
                            "text": " mail on his bicycle"
                        },
                        {
                            "text": "✓ كل صباح كان ساعي البريد "
                        },
                        {
                            "text": "يوزع",
                            "colorize": true
                        },
                        {
                            "text": " البريد بدراجته"
                        }
                    ]
                },
                {
                    "id": "card-12",
                    "type": "example",
                    "content": [
                        {
                            "text": "✓ That village "
                        },
                        {
                            "text": "used to have",
                            "colorize": true
                        },
                        {
                            "text": " no telephone service"
                        },
                        {
                            "text": "✓ كانت تلك القرية "
                        },
                        {
                            "text": "تفتقر إلى",
                            "colorize": true
                        },
                        {
                            "text": " خدمة الهاتف"
                        }
                    ]
                },
                {
                    "id": "card-13",
                    "content": [
                        {
                            "text": "✗ : That village ",
                            "colorize": true
                        },
                        {
                            "text": "would have",
                            "colorize": true
                        },
                        {
                            "text": " no telephone service"
                        },
                        {
                            "text": "✗ : تلك القرية ",
                            "colorize": true
                        },
                        {
                            "text": "would have",
                            "colorize": true
                        },
                        {
                            "text": " no telephone service"
                        }
                    ]
                },
                {
                    "id": "card-14",
                    "content": [
                        {
                            "text": "Remember:",
                            "highlight": true
                        },
                        {
                            "text": " would",
                            "colorize": true
                        },
                        {
                            "text": " works only with action verbs. ",
                            "colorize": true
                        },
                        {
                            "text": "used to",
                            "colorize": true
                        },
                        {
                            "text": " works with both"
                        },
                        {
                            "text": "تذكّر:",
                            "highlight": true
                        },
                        {
                            "text": " would ",
                            "colorize": true
                        },
                        {
                            "text": " يعمل فقط مع أفعال الحدث. ",
                            "colorize": true
                        },
                        {
                            "text": "used to",
                            "colorize": true
                        },
                        {
                            "text": " يعمل مع كليهما"
                        }
                    ]
                }
            ]
        },
