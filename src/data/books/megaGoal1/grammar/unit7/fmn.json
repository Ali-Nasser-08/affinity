                    "id": "card-27",
                    "content": [
                        {
                            "text": "Tip: Check the ",
                            "colorize": true
                        },
                        {
                            "text": "noun after the verb",
                            "colorize": true
                        },
                        {
                            "text": " to choose is or are"
                        },
                        {
                            "text": "تلميح: تحقق من ",
                            "colorize": true
                        },
                        {
                            "text": "الاسم بعد الفعل",
                            "colorize": true
                        },
                        {
                            "text": " لاختيار is أو are"
                        }
