        },
        {
            "clusterId": "cluster-4",
            "title": "There Is and There Are",
            "cards": [
                {
                    "id": "card-21",
                    "content": [
                        {
                            "text": "There Is",
                            "highlight": true
                        },
                        {
                            "text": " and ",
                            "highlight": true
                        },
                        {
                            "text": "There Are",
                            "highlight": true
                        },
                        {
                            "text": "There Is و There Are"
                        }
                    ]
                },
                {
                    "id": "card-22",
                    "content": [
                        {
                            "text": "We use these phrases to say something "
                        },
                        {
                            "text": "exists or is present",
                            "colorize2": true
                        },
                        {
                            "text": "نستخدم هذه العبارات للقول بأن شيئاً ما "
                        },
                        {
                            "text": "موجود أو حاضر",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-23",
                    "wide": true,
                    "type": "structure",
                    "content": [
                        {
                            "text": "There is",
                            "badge": true,
                            "translation": "يوجد"
                        },
                        {
                            "text": " + "
                        },
                        {
                            "text": "singular noun",
                            "badge2": true,
                            "translation": "اسم مفرد"
                        }
                    ]
                },
                {
                    "id": "card-24",
                    "type": "example",
                    "content": [
                        {
                            "text": "There is",
                            "colorize": true
                        },
                        {
                            "text": " an unread message in your inbox"
                        },
                        {
                            "text": "يوجد",
                            "colorize": true
                        },
                        {
                            "text": " رسالة غير مقروءة في صندوق الوارد"
                        }
                    ]
                },
                {
                    "id": "card-25",
                    "wide": true,
                    "type": "structure",
                    "content": [
                        {
                            "text": "There are",
                            "badge": true,
                            "translation": "توجد"
                        },
                        {
                            "text": " + "
                        },
                        {
                            "text": "plural noun",
                            "badge2": true,
                            "translation": "اسم جمع"
                        }
                    ]
                },
                {
                    "id": "card-26",
                    "type": "example",
                    "content": [
