    "clusters": [
        {
            "clusterId": "cluster-1",
            "title": "Used To for Past Habits",
            "cards": [
                {
                    "id": "card-1",
                    "content": [
                        {
                            "text": "Used To",
                            "highlight": true
                        },
                        {
                            "text": " for Past Habits and States",
                            "highlight": true
                        },
                        {
                            "text": "Used To للعادات والحالات الماضية"
                        }
                    ]
                },
                {
                    "id": "card-2",
                    "content": [
                        {
                            "text": "We use "
                        },
                        {
                            "text": "used to",
                            "colorize": true
                        },
                        {
                            "text": " for actions or situations that happened regularly before but "
                        },
                        {
                            "text": "no longer happen now",
                            "colorize2": true
                        },
                        {
                            "text": "نستخدم "
                        },
                        {
                            "text": "used to",
                            "colorize": true
                        },
                        {
                            "text": " للأفعال أو المواقف التي كانت تحدث بانتظام سابقاً لكنها "
                        },
                        {
                            "text": "لم تعد تحدث الآن",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-3",
                    "wide": true,
                    "type": "structure",
                    "content": [
                        {
                            "text": "Subject",
                            "badge": true,
                            "translation": "الفاعل"
                        },
                        {
                            "text": " + "
                        },
                        {
                            "text": "used to",
                            "badge2": true,
                            "translation": "كان"
                        },
                        {
                            "text": " + "
                        },
                        {
                            "text": "base verb",
                            "badge3": true,
                            "translation": "فعل مجرد"
                        }
                    ]
                },
                {
                    "id": "card-4",
