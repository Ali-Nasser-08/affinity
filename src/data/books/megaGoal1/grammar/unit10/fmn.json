                        {
                            "text": "get",
                            "colorize3": true
                        },
                        {
                            "text": " wet"
                        },
                        {
                            "text": "عندما",
                            "colorize": true
                        },
                        {
                            "text": " "
                        },
                        {
                            "text": "تمطر",
                            "colorize2": true
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "تبتل",
                            "colorize3": true
                        },
                        {
                            "text": " الشوارع"
                        }
                    ]
                }
            ]
        },
        {
            "clusterId": "cluster-5",
            "title": "Conditional Sentences - Future Facts",
            "cards": [
                {
                    "id": "card-31",
                    "content": [
                        {
                            "text": "Conditionals",
                            "highlight": true
                        },
                        {
                            "text": " - Future Facts"
                        },
                        {
                            "text": "الشرطية - الحقائق المستقبلية"
                        }
                    ]
                },
                {
                    "id": "card-32",
                    "wide": true,
                    "type": "structure",
                    "content": [
                        {
                            "text": "If + ",
                            "badge": true,
                            "translation": "إذا"
                        },
                        {
                            "text": "simple present",
                            "badge2": true,
                            "translation": "حاضر بسيط"
