                            "text": "If + simple present, ",
                            "badge": true
                        },
                        {
                            "text": "may/might",
                            "badge2": true,
                            "translation": "ربما"
                        },
                        {
                            "text": " + base verb",
                            "badge3": true,
                            "translation": "فعل مجرد"
