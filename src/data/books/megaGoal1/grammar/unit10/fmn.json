                        {
                            "text": "absolutely",
                            "colorize": true
                        },
                        {
                            "text": " "
                        },
                        {
                            "text": "amazing",
                            "colorize2": true
                        },
                        {
                            "text": "الحفل الموسيقي كان "
                        },
                        {
                            "text": "مذهلاً",
                            "colorize2": true
                        },
                        {
                            "text": " "
                        },
                        {
                            "text": "تماماً",
                            "colorize": true
                        }
                    ]
                },
                {
                    "id": "card-24",
                    "type": "example",
                    "content": [
                        {
                            "text": "That building is "
                        },
                        {
                            "text": "quite",
                            "colorize": true
                        },
                        {
                            "text": " "
                        },
                        {
                            "text": "massive",
                            "colorize2": true
                        },
                        {
                            "text": " (= completely massive)"
                        },
                        {
                            "text": "ذلك المبنى "
                        },
                        {
                            "text": "ضخم",
                            "colorize2": true
                        },
                        {
                            "text": " "
                        },
                        {
                            "text": "تماماً",
                            "colorize": true
                        }
                    ]
                },
                {
                    "id": "card-25",
                    "content": [
                        {
                            "text": "Note:",
                            "highlight": true
                        },
                        {
                            "text": " "
                        },
                        {
                            "text": "Really",
                            "colorize": true
                        },
