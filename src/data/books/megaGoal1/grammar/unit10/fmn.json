                            "translation": "إذا/عندما"
                        },
                        {
                            "text": "simple present",
                            "badge2": true,
                            "translation": "حاضر بسيط"
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "simple present",
                            "badge3": true,
                            "translation": "حاضر بسيط"
                        }
                    ]
