                        {
                            "text": "ملاحظة: "
                        },
                        {
                            "text": "Really",
                            "colorize": true
                        },
                        {
                            "text": " تعمل مع كلا النوعين (تعني 'كثيراً')"
                        }
                    ]
                }
            ]
        },
        {
            "clusterId": "cluster-4",
            "title": "Conditional Sentences - Present Facts",
            "cards": [
                {
                    "id": "card-26",
                    "content": [
                        {
                            "text": "Conditionals",
                            "highlight": true
                        },
                        {
                            "text": " - Present Facts"
                        },
                        {
                            "text": "الشرطية - الحقائق الحاضرة"
                        }
                    ]
                },
