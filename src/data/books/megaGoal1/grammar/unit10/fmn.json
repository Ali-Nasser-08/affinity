{
    "unit": "Mega Goal 1",
    "lesson": "Unit 10",
    "type": "Form, Meaning, and Function",
    "clusters": [
        {
            "clusterId": "cluster-1",
            "title": "Independent Clauses with Coordinating Conjunctions",
            "cards": [
                {
                    "id": "card-1",
                    "content": [
                        {
                            "text": "Independent Clauses",
                            "highlight": true
                        },
                        {
                            "text": " with Conjunctions"
                        },
                        {
                            "text": "الجمل المستقلة مع أدوات الربط"
                        }
                    ]
                },
                {
                    "id": "card-2",
                    "content": [
                        {
                            "text": "An independent clause "
                        },
                        {
                            "text": "stands alone as a complete sentence",
                            "colorize2": true
                        },
                        {
                            "text": "الجملة المستقلة "
                        },
                        {
                            "text": "تقف وحدها كجملة كاملة",
                            "colorize2": true
                        }
                    ]
                },
                {
                    "id": "card-3",
                    "type": "example",
                    "content": [
                        {
                            "text": "The storm damaged the building"
                        },
                        {
                            "text": "العاصفة ألحقت الضرر بالمبنى"
                        }
                    ]
                },
                {
                    "id": "card-4",
                    "content": [
                        {
                            "text": "Join two independent clauses with: "
                        },
                        {
                            "text": "and, but, or, so, yet",
                            "colorize": true
                        },
                        {
                            "text": "اربط جملتين مستقلتين بـ: "
                        },
                        {
                            "text": "and, but, or, so, yet",
                            "colorize": true
                        }
                    ]
                },
                {
                    "id": "card-5",
                    "content": [
                        {
                            "text": "Important:",
                            "highlight": true
                        },
                        {
                            "text": " Place a "
                        },
                        {
                            "text": "comma before the conjunction",
                            "colorize2": true
                        },
                        {
                            "text": " when joining clauses"
                        },
                        {
                            "text": "مهم: ضع "
                        },
                        {
                            "text": "فاصلة قبل أداة الربط",
                            "colorize2": true
                        },
                        {
                            "text": " عند ربط الجمل"
                        }
                    ]
                },
                {
                    "id": "card-6",
                    "type": "example",
                    "content": [
                        {
                            "text": "The power went out"
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "so",
                            "colorize": true
                        },
                        {
                            "text": " we used candles"
                        },
                        {
                            "text": "انقطعت الكهرباء"
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "لذلك",
                            "colorize": true
                        },
                        {
                            "text": " استخدمنا الشموع"
                        }
                    ]
                },
                {
                    "id": "card-7",
                    "type": "example",
                    "content": [
                        {
                            "text": "It was raining heavily"
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "yet",
                            "colorize": true
                        },
                        {
                            "text": " they decided to go out"
                        },
                        {
                            "text": "كانت تمطر بغزارة"
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "ومع ذلك",
                            "colorize": true
                        },
                        {
                            "text": " قرروا الخروج"
                        }
                    ]
                },
                {
                    "id": "card-8",
                    "type": "example",
                    "content": [
                        {
                            "text": "She studied hard"
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "and",
                            "colorize": true
                        },
                        {
                            "text": " she passed the exam"
                        },
                        {
                            "text": "درست بجد"
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "و",
                            "colorize": true
                        },
                        {
                            "text": "نجحت في الاختبار"
                        }
                    ]
                }
            ]
        },
        {
            "clusterId": "cluster-2",
            "title": "Past Events with Time Clauses",
            "cards": [
                {
                    "id": "card-9",
                    "content": [
                        {
                            "text": "Time Clauses",
                            "highlight": true
                        },
                        {
                            "text": " in the Past"
                        },
                        {
                            "text": "جمل الزمن في الماضي"
                        }
                    ]
                },
                {
                    "id": "card-10",
                    "content": [
                        {
                            "text": "Time words: "
                        },
                        {
                            "text": "when",
                            "colorize": true
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "as soon as",
                            "colorize2": true
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "before",
                            "colorize": true
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "after",
                            "colorize2": true
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "while",
                            "colorize": true
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "until",
                            "colorize2": true
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "since",
                            "colorize": true
                        },
                        {
                            "text": "كلمات الزمن: "
                        },
                        {
                            "text": "عندما",
                            "colorize": true
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "بمجرد",
                            "colorize2": true
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "قبل",
                            "colorize": true
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "بعد",
                            "colorize2": true
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "بينما",
                            "colorize": true
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "حتى",
                            "colorize2": true
                        },
                        {
                            "text": "، "
                        },
                        {
                            "text": "منذ",
                            "colorize": true
                        }
                    ]
                },
                {
                    "id": "card-11",
                    "content": [
                        {
                            "text": "When the time clause comes first, use a "
                        },
                        {
                            "text": "comma",
                            "colorize2": true
                        },
                        {
                            "text": " after it"
                        },
                        {
                            "text": "عندما تأتي جملة الزمن أولاً، استخدم "
                        },
                        {
                            "text": "فاصلة",
                            "colorize2": true
                        },
                        {
                            "text": " بعدها"
                        }
                    ]
                },
                {
                    "id": "card-12",
                    "type": "example",
                    "content": [
                        {
                            "text": "When",
                            "colorize": true
                        },
                        {
                            "text": " she arrived home"
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "she found a package"
                        },
                        {
                            "text": "عندما",
                            "colorize": true
                        },
                        {
                            "text": " وصلت إلى المنزل، وجدت طرداً"
                        }
                    ]
                },
                {
                    "id": "card-13",
                    "type": "example",
                    "content": [
                        {
                            "text": "After",
                            "colorize": true
                        },
                        {
                            "text": " we finished dinner"
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "we watched a movie"
                        },
                        {
                            "text": "بعد",
                            "colorize": true
                        },
                        {
                            "text": " أن أنهينا العشاء، شاهدنا فيلماً"
                        }
                    ]
                },
                {
                    "id": "card-14",
                    "type": "example",
                    "content": [
                        {
                            "text": "As soon as",
                            "colorize": true
                        },
                        {
                            "text": " he heard the news"
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "he called his family"
                        },
                        {
                            "text": "بمجرد",
                            "colorize": true
                        },
                        {
                            "text": " أن سمع الخبر، اتصل بعائلته"
                        }
                    ]
                },
                {
                    "id": "card-15",
                    "type": "example",
                    "content": [
                        {
                            "text": "While",
                            "colorize": true
                        },
                        {
                            "text": " I was reading"
                        },
                        {
                            "text": ", "
                        },
                        {
                            "text": "my phone rang"
                        },
                        {
                            "text": "بينما",
                            "colorize": true
                        },
                        {
                            "text": " كنت أقرأ، رن هاتفي"
                        }
                    ]
                }
            ]
        },
        {
            "clusterId": "cluster-3",
            "title": "Intensifiers with Adjectives",
            "cards": [
                {
                    "id": "card-16",
                    "content": [
                        {
                            "text": "Expressing Enthusiasm",
                            "highlight": true
                        },
                        {
                            "text": " with Intensifiers"
                        },
                        {
                            "text": "التعبير عن الحماس بالمكثفات"
                        }
                    ]
                },
                {
                    "id": "card-17",
                    "content": [
                        {
                            "text": "Gradable Adjectives",
                            "highlight": true
                        },
                        {
                            "text": " (can be more/less)"
                        },
                        {
                            "text": "صفات قابلة للتدرج (يمكن أن تكون أكثر/أقل)"
                        }
                    ]
                },
                {
                    "id": "card-18",
                    "content": [
                        {
                            "text": "Use: "
                        },
                        {
                            "text": "very, really, quite",
                            "colorize": true
                        },
                        {
                            "text": " + gradable adjectives (big, small, interesting, good)"
                        },
                        {
                            "text": "استخدم: "
                        },
                        {
                            "text": "very, really, quite",
                            "colorize": true
                        },
                        {
                            "text": " + صفات قابلة للتدرج"
                        }
                    ]
                },
                {
                    "id": "card-19",
                    "type": "example",
                    "content": [
                        {
                            "text": "The movie was "
                        },
                        {
                            "text": "very",
                            "colorize": true
                        },
                        {
                            "text": " "
                        },
                        {
                            "text": "interesting",
                            "colorize2": true
                        },
                        {
                            "text": "الفيلم كان "
                        },
                        {
                            "text": "مثيراً للاهتمام",
                            "colorize2": true
                        },
                        {
                            "text": " "
                        },
                        {
                            "text": "جداً",
                            "colorize": true
                        }
                    ]
                },
                {
                    "id": "card-20",
                    "type": "example",
                    "content": [
                        {
                            "text": "This room is "
                        },
                        {
                            "text": "quite",
                            "colorize": true
                        },
                        {
                            "text": " "
                        },
                        {
                            "text": "small",
                            "colorize2": true
                        },
                        {
                            "text": " (= a little small)"
                        },
                        {
                            "text": "هذه الغرفة "
                        },
                        {
                            "text": "صغيرة",
                            "colorize2": true
                        },
                        {
                            "text": " "
                        },
                        {
                            "text": "نوعاً ما",
                            "colorize": true
                        }
                    ]
                },
                {
                    "id": "card-21",
                    "content": [
                        {
                            "text": "Non-Gradable Adjectives",
                            "highlight": true
                        },
                        {
                            "text": " (extreme meanings)"
                        },
                        {
                            "text": "صفات غير قابلة للتدرج (معانٍ قصوى)"
