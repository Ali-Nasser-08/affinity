        {
            "clusterId": "cluster-6",
            "title": "Conditionals with May/Might",
            "cards": [
                {
                    "id": "card-35",
                    "content": [
                        {
                            "text": "Conditionals with ",
                            "highlight": true
                        },
                        {
                            "text": "May/Might",
                            "highlight": true
                        },
                        {
                            "text": "الشرطية مع May/Might"
                        }
                    ]
                },
                {
                    "id": "card-36",
                    "content": [
                        {
                            "text": "Use "
                        },
                        {
                            "text": "may/might",
                            "colorize": true
                        },
