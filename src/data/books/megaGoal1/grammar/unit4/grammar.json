            {
              "text": "the + adjective + -est",
              "badge": true,
              "translation": "the + صفة + est"
            },
            {
              "text": " or "
            },
            {
              "text": "the most + adjective",
              "badge2": true,
              "translation": "the most + صفة"
            }
          ]
        },
        {
          "id": "card-17b",
          "type": "example",
          "content": [
            {
              "text": "This is "
            },
            {
              "text": "the fastest",
              "colorize": true
            },
            {
              "text": " train in the country"
            },
            {
              "text": "هذا "
            },
            {
              "text": "الأسرع",
              "colorize": true
            },
            {
              "text": " قطار في البلاد"
            }
          ]
        },
        {
          "id": "card-18",
          "type": "example",
          "content": [
            {
              "text": "It's "
            },
            {
              "text": "the most advanced",
              "colorize2": true
            },
            {
