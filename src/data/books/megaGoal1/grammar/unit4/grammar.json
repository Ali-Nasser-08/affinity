  "clusters": [
    {
      "clusterId": "cluster-1",
      "title": "The Passive Voice",
      "cards": [
        {
          "id": "card-1",
          "content": [
            {
              "text": "The Passive Voice",
              "highlight": true
            },
            {
              "text": "المبني للمجهول"
            }
          ]
        },
        {
          "id": "card-2",
          "content": [
            {
              "text": "The passive focuses on "
            },
            {
              "text": "the action itself",
              "colorize2": true
            },
            {
              "text": " rather than "
            },
            {
              "text": "who performed it",
              "colorize2": true
            },
            {
              "text": "المبني للمجهول يركز على "
            },
            {
              "text": "الفعل نفسه",
              "colorize2": true
            },
            {
              "text": " بدلاً من "
            },
            {
              "text": "من قام به",
              "colorize2": true
            }
          ]
        },
        {
          "id": "card-3",
          "wide": true,
          "type": "structure",
          "content": [
            {
              "text": " "
            },
            {
              "text": "be",
              "badge": true,
              "translation": "فعل مساعد"
            },
            {
              "text": " + "
            },
            {
              "text": "past participle",
              "badge2": true,
              "translation": "التصريف الثالث"
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-2",
      "title": "Passive in Different Tenses",
      "cards": [
        {
          "id": "card-4",
          "content": [
            {
              "text": "Passive in Different Tenses",
              "highlight": true
            },
            {
              "text": "المبني للمجهول في أزمنة مختلفة"
            }
          ]
        },
        {
          "id": "card-5",
          "wide": true,
          "type": "structure",
          "content": [
            {
              "text": "Simple Present:",
              "colorize2": true
            },
            {
              "text": " "
            },
            {
              "text": "am/is/are",
              "badge": true,
              "translation": "فعل مساعد"
            },
            {
              "text": " + "
            },
            {
              "text": "past participle",
              "badge2": true,
              "translation": "التصريف الثالث"
            }
          ]
        },
        {
          "id": "card-5b",
          "type": "example",
          "content": [
            {
              "text": "These phones "
            },
            {
              "text": "are",
              "colorize": true
            },
            {
              "text": " "
            },
            {
              "text": "manufactured",
              "colorize2": true
            },
            {
              "text": " in Korea"
            },
            {
              "text": "هذه الهواتف "
            },
            {
              "text": "تُصنع",
              "colorize2": true
            },
            {
              "text": " في كوريا"
            }
          ]
        },
        {
          "id": "card-6",
          "wide": true,
          "type": "structure",
          "content": [
            {
              "text": "Simple Past:",
              "colorize2": true
            },
            {
              "text": " "
            },
            {
              "text": "was/were",
              "badge": true,
              "translation": "فعل مساعد"
            },
            {
              "text": " + "
            },
            {
              "text": "past participle",
              "badge2": true,
              "translation": "التصريف الثالث"
            }
          ]
        },
        {
          "id": "card-6b",
          "type": "example",
          "content": [
            {
              "text": "The laptop "
