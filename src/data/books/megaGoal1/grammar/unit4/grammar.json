    {
      "clusterId": "cluster-3",
      "title": "Passive with 'by' Phrase",
      "cards": [
        {
          "id": "card-9",
          "content": [
            {
              "text": "Showing the Doer with 'by'",
              "highlight": true
            },
            {
              "text": "إظهار الفاعل بـ 'by'"
            }
          ]
        },
        {
          "id": "card-10",
          "content": [
            {
              "text": "Add "
            },
            {
              "text": "by + noun",
              "colorize": true
            },
            {
              "text": " after the passive when you want to mention "
            },
            {
              "text": "who did the action",
              "colorize2": true
            },
            {
              "text": "أضف "
            },
            {
              "text": "by + اسم",
              "colorize": true
            },
            {
              "text": " بعد المبني للمجهول عندما تريد ذكر "
            },
            {
              "text": "من قام بالفعل",
              "colorize2": true
            }
          ]
        },
        {
          "id": "card-11",
          "type": "example",
          "content": [
            {
              "text": "The novel was written "
            },
            {
              "text": "by a famous author",
              "colorize": true
            },
            {
              "text": "الرواية كُتبت "
            },
            {
              "text": "بواسطة مؤلف مشهور",
              "colorize": true
            }
          ]
        },
        {
          "id": "card-12",
          "type": "example",
          "content": [
            {
              "text": "This building was constructed "
            },
            {
              "text": "by skilled engineers",
              "colorize": true
            },
            {
              "text": "هذا المبنى بُني "
            },
            {
              "text": "بواسطة مهندسين ماهرين",
              "colorize": true
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-4",
      "title": "Comparison of Adjectives",
      "cards": [
        {
          "id": "card-13",
          "content": [
            {
              "text": "Comparison of Adjectives",
              "highlight": true
            },
            {
              "text": "مقارنة الصفات"
            }
          ]
        },
        {
          "id": "card-14",
          "content": [
            {
              "text": "When comparing "
            },
            {
              "text": "two or more items",
              "colorize2": true
            },
            {
              "text": ", change the adjective form"
            },
            {
              "text": "عند مقارنة "
            },
            {
              "text": "عنصرين أو أكثر",
              "colorize2": true
            },
            {
              "text": "، غيّر شكل الصفة"
            }
          ]
        },
        {
          "id": "card-15",
          "wide": true,
          "type": "structure",
          "content": [
            {
              "text": "Comparative (for 2 things):",
              "colorize2": true
            },
            {
              "text": " "
            },
            {
              "text": "adjective + -er",
              "badge": true,
              "translation": "صفة + er"
            },
            {
              "text": " or "
            },
            {
              "text": "more + adjective",
              "badge2": true,
              "translation": "more + صفة"
            }
          ]
        },
        {
          "id": "card-15b",
          "type": "example",
          "content": [
            {
              "text": "This phone is "
            },
            {
              "text": "faster",
              "colorize": true
            },
            {
              "text": " than my old one"
            },
            {
              "text": "هذا الهاتف "
            },
            {
              "text": "أسرع",
              "colorize": true
            },
            {
              "text": " من هاتفي القديم"
            }
          ]
        },
        {
          "id": "card-16",
          "type": "example",
          "content": [
            {
              "text": "The new model is "
            },
            {
              "text": "more efficient",
              "colorize2": true
            },
            {
              "text": " than the previous one"
            },
            {
              "text": "الطراز الجديد "
            },
            {
              "text": "أكثر كفاءة",
              "colorize2": true
            },
            {
              "text": " من السابق"
            }
