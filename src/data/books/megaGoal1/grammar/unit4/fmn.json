  "type": "Form, Meaning, and Function",
  "clusters": [
    {
      "clusterId": "cluster-1",
      "title": "Demonstrative Pronouns",
      "cards": [
        {
          "id": "card-1",
          "content": [
            {
              "text": "Demonstrative Pronouns",
              "highlight": true
            },
            {
              "text": "الضمائر الإشارية"
            }
          ]
        },
        {
          "id": "card-2",
          "content": [
            {
              "text": "Use demonstrative pronouns to "
            },
            {
              "text": "point to objects",
              "colorize2": true
            },
            {
              "text": " and show their "
            },
            {
              "text": "distance",
              "colorize2": true
            },
            {
              "text": " from you"
            },
            {
              "text": "تُستخدم الضمائر الإشارية للإشارة إلى الأشياء وتحديد قربها أو بعدها عن المتكلّم"
            }
          ]
        },
        {
          "id": "card-3",
          "wide": true,
          "type": "structure",
          "content": [
            {
              "text": "Near (singular)",
              "badge": true,
              "translation": "مفرد قريب"
            },
            {
              "text": " → "
            },
            {
              "text": "This",
              "badge2": true,
              "translation": "هَـذَا / هَـذِه"
            },
            {
              "text": " | Far (singular) → "
            },
            {
              "text": "That",
              "badge3": true,
              "translation": "ذَلِكَ / تِلْكَ"
            }
          ]
        },
        {
          "id": "card-4",
          "wide": true,
          "type": "structure",
          "content": [
            {
              "text": "Near (plural)",
              "badge": true,
              "translation": "جمع قريب"
            },
            {
              "text": " → "
            },
            {
              "text": "These",
              "badge2": true,
              "translation": "هَـؤُلَاءِ"
            },
            {
              "text": " | Far (plural) → "
            },
            {
              "text": "Those",
              "badge3": true,
              "translation": "أُولَـٰئِكَ"
            }
          ]
        },
        {
          "id": "card-5",
          "type": "example",
          "content": [
            {
              "text": "I like "
            },
            {
              "text": "this",
              "colorize": true
            },
            {
              "text": " phone here"
            },
            {
              "text": "أحبُّ "
            },
            {
              "text": "هذا",
              "colorize": true
            },
            {
              "text": " الهاتف هنا"
            }
          ]
        },
        {
          "id": "card-6",
          "type": "example",
          "content": [
            {
              "text": "Do you see "
            },
            {
              "text": "that",
              "colorize": true
            },
            {
              "text": " building over there?"
            },
            {
              "text": "هل ترى "
            },
            {
              "text": "ذلك",
              "colorize": true
            },
            {
              "text": " المبنى هناك؟"
            }
          ]
        },
        {
          "id": "card-7",
          "type": "example",
          "content": [
            {
              "text": "Are "
            },
            {
              "text": "these",
              "colorize": true
            },
            {
              "text": " your keys?"
            },
            {
              "text": "هل "
            },
            {
              "text": "هذه",
              "colorize": true
            },
            {
              "text": " مفاتيحك؟"
            }
          ]
        },
        {
          "id": "card-8",
          "type": "example",
          "content": [
            {
              "text": "I prefer "
            },
            {
              "text": "those",
              "colorize": true
            },
            {
              "text": " shoes in the window"
            },
            {
              "text": "أُفضّل "
            },
            {
              "text": "تلك",
              "colorize": true
            },
            {
              "text": " الأحذية في النافذة"
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-2",
      "title": "Imperatives",
      "cards": [
        {
          "id": "card-9",
          "content": [
            {
              "text": "Imperatives",
              "highlight": true
            },
            {
              "text": "صيغة الأمر"
            }
          ]
        },
        {
          "id": "card-10",
          "content": [
            {
              "text": "Use the imperative form for "
            },
            {
              "text": "commands",
              "colorize2": true
            },
            {
              "text": ", "
            },
            {
              "text": "instructions",
              "colorize2": true
            },
            {
              "text": ", and "
            },
            {
              "text": "advice",
              "colorize2": true
            },
            {
              "text": "تُستخدم صيغة الأمر لإعطاء الأوامر والتعليمات والنصائح"
            }
          ]
        },
        {
          "id": "card-11",
          "type": "example",
          "content": [
            {
              "text": "Please",
              "colorize": true
            },
            {
              "text": " sit down"
            },
            {
              "text": "من فضلك "
            },
            {
              "text": "اجلس",
              "colorize": true
            }
          ]
        },
        {
          "id": "card-12",
          "type": "example",
          "content": [
            {
              "text": "Open",
              "colorize": true
            },
            {
              "text": " your books to page 10"
            },
            {
              "text": "افتحوا ",
              "colorize": true
            },
            {
              "text": "كتبكم"
            },
            {
              "text": " على الصفحة 10"
            }
          ]
        },
        {
          "id": "card-13",
          "type": "example",
          "content": [
            {
              "text": "Don't forget",
              "colorize": true
            },
            {
              "text": " to call me"
            },
            {
              "text": "لا "
            },
            {
              "text": "تَنْسَ",
              "colorize": true
            },
            {
              "text": " أن تتصل بي"
            }
          ]
        },
        {
          "id": "card-14",
          "content": [
            {
              "text": "Tip:",
              "highlight": true
            },
            {
              "text": " Add "
            },
            {
              "text": "please",
              "colorize2": true
            },
            {
              "text": " to make imperatives more polite and friendly"
            },
            {
              "text": "نصيحة: أضف \"من فضلك\" لجعل الأمر أكثر لباقة"
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-3",
      "title": "Indefinite Articles",
      "cards": [
        {
          "id": "card-15",
          "content": [
            {
              "text": "Indefinite Articles",
              "highlight": true
            },
            {
              "text": "حروف التنكير"
            }
          ]
        },
        {
          "id": "card-16",
          "content": [
            {
              "text": "Use "
            },
            {
              "text": "a",
              "colorize": true
            },
            {
              "text": " and "
            },
            {
              "text": "an",
              "colorize": true
            },
            {
              "text": " before singular nouns when referring to "
            },
            {
              "text": "non-specific",
              "colorize2": true
            },
            {
              "text": " items"
            },
            {
              "text": "تُستخدم حروف التنكير قبل الأسماء المفردة عند الإشارة إلى شيء غير معيّن"
            }
          ]
        },
        {
          "id": "card-17",
          "wide": true,
          "type": "structure",
          "content": [
            {
              "text": "a",
              "badge": true,
              "translation": "للسكون"
            },
            {
              "text": " + consonant sound",
              "colorize": true
            },
            {
              "text": " | "
            },
            {
              "text": "an",
              "badge2": true,
              "translation": "للحركة"
            },
            {
              "text": " + vowel sound",
              "colorize2": true
            }
          ]
        },
        {
          "id": "card-18",
          "type": "example",
          "content": [
            {
              "text": "a",
              "colorize": true
            },
            {
              "text": " book"
            },
            {
              "text": "كتابٌ"
            }
          ]
        },
        {
          "id": "card-19",
          "type": "example",
          "content": [
            {
              "text": "an",
              "colorize": true
            },
            {
              "text": " apple"
            },
            {
              "text": "تفاحةٌ"
            }
          ]
        },
        {
          "id": "card-20",
          "type": "example",
          "content": [
            {
              "text": "a",
              "colorize": true
            },
            {
              "text": " university (sounds like 'y')"
            },
            {
              "text": "جامعةٌ"
            }
          ]
        },
        {
          "id": "card-21",
          "type": "example",
          "content": [
            {
              "text": "an",
              "colorize": true
            },
            {
              "text": " hour (silent 'h')"
            },
            {
              "text": "ساعةٌ"
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-4",
      "title": "Possessive Adjectives and Pronouns",
      "cards": [
        {
          "id": "card-22",
          "content": [
            {
              "text": "Possessive Adjectives vs Pronouns",
              "highlight": true
            },
            {
              "text": "الضمائر الملكية المتصلة والمنفصلة"
            }
          ]
        },
        {
          "id": "card-23",
          "content": [
            {
              "text": "Possessive adjectives"
            },
            {
              "text": " come before a noun",
              "colorize2": true
            },
            {
              "text": ". Possessive pronouns"
            },
            {
              "text": " replace the noun",
              "colorize2": true
            },
            {
              "text": "الضمائر المتصلة تسبق الاسم، والمنفصلة تحل محله"
            }
          ]
        },
        {
          "id": "card-24",
          "wide": true,
          "type": "structure",
          "content": [
            {
              "text": "Adjective",
              "badge": true,
              "translation": "متصل"
            },
            {
              "text": " → "
            },
            {
              "text": "Pronoun",
              "badge2": true,
              "translation": "منفصل"
            }
          ]
        },
        {
          "id": "card-25",
          "type": "example",
          "content": [
            {
              "text": "my",
              "colorize": true
            },
            {
              "text": " → "
            },
            {
              "text": "mine",
              "colorize": true
            }
          ]
        },
        {
          "id": "card-26",
          "type": "example",
          "content": [
            {
              "text": "your",
              "colorize": true
            },
            {
              "text": " → "
            },
            {
              "text": "yours",
              "colorize": true
            }
          ]
        },
        {
          "id": "card-27",
          "type": "example",
          "content": [
            {
              "text": "his",
              "colorize": true
            },
            {
              "text": " → "
            },
            {
              "text": "his",
              "colorize": true
            }
          ]
        },
        {
          "id": "card-28",
          "type": "example",
          "content": [
            {
              "text": "her",
              "colorize": true
            },
            {
              "text": " → "
            },
            {
              "text": "hers",
              "colorize": true
            }
          ]
        },
        {
          "id": "card-29",
          "type": "example",
          "content": [
            {
              "text": "our",
              "colorize": true
            },
            {
              "text": " → "
            },
            {
              "text": "ours",
              "colorize": true
            }
          ]
        },
        {
          "id": "card-30",
          "type": "example",
          "content": [
            {
              "text": "their",
              "colorize": true
            },
            {
              "text": " → "
            },
            {
              "text": "theirs",
              "colorize": true
            }
          ]
        },
        {
          "id": "card-31",
          "type": "example",
          "content": [
            {
              "text": "This is "
            },
            {
              "text": "my",
              "colorize": true
            },
            {
              "text": " phone. The phone is "
            },
            {
              "text": "mine",
              "colorize2": true
            },
            {
              "text": "هذا "
            },
            {
              "text": "هاتفي",
              "colorize": true
            },
            {
              "text": ". الهاتف "
            },
            {
              "text": "لي",
              "colorize2": true
            }
          ]
        },
        {
          "id": "card-32",
          "type": "example",
          "content": [
            {
              "text": "It's "
            },
            {
              "text": "his",
              "colorize": true
            },
            {
              "text": " cell phone. It's "
            },
            {
              "text": "his",
              "colorize2": true
            },
            {
              "text": "إنه "
            },
            {
              "text": "هاتفه",
              "colorize": true
            },
            {
              "text": ". إنه "
            },
            {
              "text": "له",
              "colorize2": true
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-5",
      "title": "Whose Questions",
      "cards": [
        {
          "id": "card-33",
          "content": [
            {
              "text": "Whose",
              "highlight": true
            },
            {
              "text": "Questions about Ownership"
            },
            {
              "text": "الاستفسار عن الملكية"
            }
          ]
        },
        {
          "id": "card-34",
          "content": [
            {
              "text": "Use "
            },
            {
              "text": "whose",
              "colorize": true
            },
            {
              "text": " to ask about "
