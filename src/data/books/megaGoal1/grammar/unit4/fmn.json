            {
              "text": "ownership",
              "colorize2": true
            },
            {
              "text": " or who something belongs to"
            },
            {
              "text": "تُستخدم \"لِمَن\" للسؤال عن صاحب الشيء"
            }
          ]
        },
        {
          "id": "card-35",
          "type": "example",
          "content": [
            {
              "text": "Whose",
              "colorize": true
            },
            {
              "text": " credit card is this?"
            },
            {
              "text": "لِمَنْ ",
              "colorize": true
            },
            {
              "text": "هذه البطاقة؟"
            }
          ]
        },
        {
          "id": "card-36",
          "type": "example",
          "content": [
            {
              "text": "It's "
            },
            {
              "text": "mine",
              "colorize": true
            },
            {
              "text": ". It belongs to "
            },
            {
              "text": "me",
              "colorize2": true
            },
            {
              "text": "إنها ",
              "colorize": true
            },
            {
              "text": "لي",
              "colorize2": true
            }
          ]
        },
        {
          "id": "card-37",
          "type": "example",
          "content": [
            {
              "text": "Whose",
              "colorize": true
            },
            {
              "text": " shopping bags are these?"
            },
            {
              "text": "لِمَنْ ",
              "colorize": true
            },
            {
              "text": "هذه الأكياس؟"
            }
          ]
        },
        {
          "id": "card-38",
          "type": "example",
          "content": [
            {
              "text": "They're "
            },
            {
              "text": "hers",
              "colorize": true
            },
            {
              "text": "."
            },
            {
              "text": "They belong to ",
              "colorize2": true
            },
            {
              "text": "that lady",
              "colorize2": true
            },
            {
              "text": "إنها ",
              "colorize": true
            },
            {
              "text": "لها",
              "colorize2": true
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-6",
      "title": "One and Ones",
      "cards": [
        {
          "id": "card-39",
          "content": [
            {
              "text": "Using One and Ones",
              "highlight": true
            },
            {
              "text": "الضمير البديل (للمفرد والجمع)"
            }
          ]
        },
        {
          "id": "card-40",
          "content": [
            {
              "text": "Use "
            },
            {
              "text": "one",
              "colorize": true
            },
            {
              "text": " (singular) and "
            },
            {
              "text": "ones",
              "colorize": true
            },
            {
              "text": " (plural) to "
            },
            {
              "text": "replace nouns",
              "colorize2": true
            },
            {
              "text": " and avoid repetition"
            },
            {
              "text": "يُستخدم الضمير البديل لاستبدال الأسماء وتجنب التكرار"
            }
          ]
        },
        {
          "id": "card-41",
          "type": "example",
          "content": [
            {
              "text": "Q: Which coat do you like?"
            },
            {
              "text": "س: أيُّ معطف تُفضّل؟"
            }
          ]
        },
        {
          "id": "card-42",
          "type": "example",
          "content": [
            {
              "text": "A: The green ",
              "colorize": true
            },
            {
              "text": "one",
              "colorize": true
            },
            {
              "text": " (replaces coat)"
            },
            {
              "text": "ج: الأخضر"
            }
          ]
        },
        {
          "id": "card-43",
          "type": "example",
          "content": [
            {
              "text": "Q: Which boots do you prefer?"
            },
            {
              "text": "س: أيُّ جزم تُفضّل؟"
            }
          ]
        },
        {
          "id": "card-44",
          "type": "example",
          "content": [
            {
              "text": "A: The leather ",
              "colorize": true
            },
            {
              "text": "ones",
              "colorize": true
            },
            {
              "text": " (replaces boots)"
            },
            {
              "text": "ج: الجلدية"
            }
          ]
        },
        {
          "id": "card-45",
          "content": [
            {
              "text": "Note:",
              "highlight": true
            },
            {
              "text": " Use ",
              "colorize": true
            },
            {
              "text": "one",
              "colorize": true
            },
            {
              "text": " for singular nouns and ",
              "colorize": true
            },
            {
              "text": "ones",
              "colorize": true
            },
            {
              "text": " for plural nouns"
            },
            {
              "text": "ملاحظة: واحد للمفرد، وجمع للجمع"
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-7",
      "title": "Too and Enough",
      "cards": [
        {
          "id": "card-46",
          "content": [
            {
              "text": "Too and Enough",
              "highlight": true
            },
            {
              "text": "الفرق بين \"جداً\" و\"بما يكفي\""
            }
          ]
        },
        {
          "id": "card-47",
          "content": [
            {
              "text": "Too",
              "colorize": true
            },
            {
              "text": " means "
            },
            {
              "text": "more than necessary",
              "colorize": true
            },
            {
              "text": " (excessive). ",
              "colorize": true
            },
            {
              "text": "\n"
            },
            {
              "text": "Enough",
              "colorize2": true
            },
            {
              "text": " means "
            },
            {
              "text": "sufficient",
              "colorize2": true
            },
            {
              "text": " or the right amount",
              "colorize2": true
            },
            {
              "text": "\"جداً\" تعني أكثر من اللازم، و\"بما يكفي\" تعني بالقدر الكافي"
            }
          ]
        },
        {
          "id": "card-48",
          "type": "example",
          "content": [
            {
              "text": "This jacket is "
            },
            {
              "text": "too",
              "colorize": true
            },
            {
              "text": " small",
              "colorize": true
            },
            {
              "text": " for me"
            },
            {
              "text": "هذا المعطف "
            },
            {
              "text": "ضيّقٌ جداً",
              "colorize": true
            },
            {
              "text": " عليّ"
            }
          ]
        },
        {
          "id": "card-49",
          "type": "example",
          "content": [
            {
              "text": "The shoes are "
            },
            {
              "text": "too",
              "colorize": true
            },
            {
              "text": " big",
              "colorize": true
            },
            {
              "text": "الأحذية "
            },
            {
              "text": "واسعةٌ جداً",
              "colorize": true
            }
          ]
        },
        {
          "id": "card-50",
          "type": "example",
          "content": [
            {
              "text": "The jacket is"
            },
            {
              "text": " not big ",
              "colorize2": true
            },
            {
              "text": "enough",
              "colorize2": true
            },
            {
              "text": " for me"
            },
            {
              "text": "المعطف ليس"
            },
            {
              "text": " واسعاً ",
              "colorize2": true
            },
            {
              "text": "بما يكفي",
              "colorize2": true
            },
            {
              "text": " لي"
            }
          ]
