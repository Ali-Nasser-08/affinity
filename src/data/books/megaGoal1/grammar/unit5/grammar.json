{
  "unit": "Mega Goal 1",
  "lesson": "Unit 5",
  "clusters": [
    {
      "clusterId": "cluster-1",
      "title": "Reflexive Pronouns",
      "cards": [
        {
          "id": "card-1",
          "content": [
            {
              "text": "Reflexive Pronouns",
              "highlight": true
            },
            {
              "text": "ضمائر الانعكاس"
            }
          ]
        },
        {
          "id": "card-2",
          "content": [
            {
              "text": "When the "
            },
            {
              "text": "same person",
              "colorize2": true
            },
            {
              "text": " is both doing and receiving the action, use a reflexive pronoun"
            },
            {
              "text": "عندما يكون "
            },
            {
              "text": "نفس الشخص",
              "colorize2": true
            },
            {
              "text": " يقوم بالفعل ويستقبله، استخدم ضمير الانعكاس"
            }
          ]
        },
        {
          "id": "card-3",
          "wide": true,
          "type": "structure",
          "content": [
            {
              "text": "Singular: "
            },
            {
              "text": "myself",
              "badge": true,
              "translation": "نفسي"
            },
            {
              "text": ", "
            },
            {
              "text": "yourself",
              "badge": true,
              "translation": "نفسك"
            },
            {
              "text": ", "
            },
            {
              "text": "himself/herself/itself",
              "badge": true,
              "translation": "نفسه/نفسها"
            }
          ]
        },
        {
          "id": "card-4",
          "wide": true,
          "type": "structure",
          "content": [
            {
              "text": "Plural: "
            },
            {
              "text": "ourselves",
              "badge2": true,
              "translation": "أنفسنا"
            },
            {
              "text": ", "
            },
            {
              "text": "yourselves",
              "badge2": true,
              "translation": "أنفسكم"
            },
            {
              "text": ", "
            },
            {
              "text": "themselves",
              "badge2": true,
              "translation": "أنفسهم"
            }
          ]
        },
        {
          "id": "card-5",
          "type": "example",
          "content": [
            {
              "text": "She taught "
            },
            {
              "text": "herself",
              "colorize": true
            },
            {
              "text": " how to play guitar"
            },
            {
              "text": "علّمت "
            },
            {
              "text": "نفسها",
              "colorize": true
            },
            {
              "text": " كيف تعزف الجيتار"
            }
          ]
        },
        {
          "id": "card-6",
          "type": "example",
          "content": [
            {
              "text": "We enjoyed "
            },
            {
              "text": "ourselves",
              "colorize": true
            },
            {
              "text": " at the party"
            },
            {
              "text": "استمتعنا "
            },
            {
              "text": "بأنفسنا",
              "colorize": true
            },
            {
              "text": " في الحفلة"
            }
          ]
        },
        {
          "id": "card-7",
          "content": [
            {
              "text": "Note:",
              "highlight": true
            },
            {
              "text": " Reflexive pronouns can show you "
            },
            {
              "text": "did something alone",
              "colorize2": true
            },
            {
              "text": " without help"
            },
            {
              "text": "ملاحظة: ضمائر الانعكاس يمكن أن تظهر أنك "
            },
            {
              "text": "فعلت شيئاً بمفردك",
              "colorize2": true
            },
            {
              "text": " بدون مساعدة"
            }
          ]
        },
        {
          "id": "card-8",
          "type": "example",
          "content": [
            {
              "text": "I repaired the computer "
            },
            {
              "text": "myself",
              "colorize": true
            },
            {
              "text": "أصلحت الكمبيوتر "
            },
            {
              "text": "بنفسي",
              "colorize": true
            }
          ]
        },
        {
          "id": "card-9",
          "type": "example",
          "content": [
            {
              "text": "They built the house "
            },
            {
              "text": "themselves",
              "colorize": true
            },
            {
              "text": "بنوا المنزل "
            },
            {
              "text": "بأنفسهم",
              "colorize": true
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-2",
      "title": "Because versus So",
      "cards": [
        {
          "id": "card-10",
          "content": [
            {
              "text": "Because",
              "highlight": true
            },
            {
              "text": " versus ",
              "highlight": true
            },
            {
              "text": "So",
              "highlight": true
            },
            {
              "text": "Because مقابل So"
            }
          ]
        },
        {
          "id": "card-11",
          "content": [
            {
              "text": "Because",
              "colorize": true
            },
            {
              "text": " introduces a "
            },
            {
              "text": "reason",
              "colorize2": true
            },
            {
              "text": " (explains why something happened)"
            },
            {
              "text": "Because",
              "colorize": true
            },
            {
              "text": " تقدم "
            },
            {
              "text": "السبب",
              "colorize2": true
            },
            {
              "text": " (تشرح لماذا حدث شيء)"
            }
          ]
        },
        {
          "id": "card-12",
          "type": "example",
          "content": [
            {
              "text": "She stayed home "
            },
            {
              "text": "because",
              "colorize": true
            },
            {
              "text": " she was tired"
            },
            {
              "text": "بقيت في المنزل "
            },
            {
              "text": "لأنها",
              "colorize": true
            },
            {
              "text": " كانت متعبة"
            }
          ]
        },
        {
          "id": "card-13",
          "type": "example",
          "content": [
            {
              "text": "Many injuries occur "
            },
            {
              "text": "because",
              "colorize": true
            },
            {
              "text": " people are careless"
            },
            {
              "text": "تحدث العديد من الإصابات "
            },
            {
              "text": "لأن",
              "colorize": true
            },
            {
              "text": " الناس مهملون"
            }
          ]
        },
        {
          "id": "card-14",
          "content": [
            {
              "text": "So",
              "colorize": true
            },
            {
              "text": " introduces a "
            },
            {
              "text": "result or consequence",
              "colorize2": true
            },
            {
              "text": " (shows what happened next)"
            },
            {
              "text": "So",
              "colorize": true
            },
            {
              "text": " تقدم "
            },
            {
              "text": "نتيجة أو عواقب",
              "colorize2": true
            },
            {
              "text": " (تظهر ما حدث بعد ذلك)"
            }
          ]
        },
        {
          "id": "card-15",
          "type": "example",
          "content": [
            {
              "text": "She was tired, "
            },
            {
              "text": "so",
              "colorize": true
            },
            {
              "text": " she went to bed early"
            },
            {
              "text": "كانت متعبة، "
            },
            {
              "text": "لذلك",
              "colorize": true
            },
            {
              "text": " ذهبت للنوم مبكراً"
            }
          ]
        },
        {
          "id": "card-16",
          "type": "example",
          "content": [
            {
              "text": "He forgot to study, "
            },
            {
              "text": "so",
              "colorize": true
            },
            {
              "text": " he failed the test"
            },
            {
              "text": "نسي أن يدرس، "
            },
            {
              "text": "لذلك",
              "colorize": true
            },
            {
              "text": " رسب في الاختبار"
            }
          ]
        }
      ]
    },
    {
      "clusterId": "cluster-3",
      "title": "So and Neither - Showing Agreement",
      "cards": [
        {
          "id": "card-17",
          "content": [
            {
              "text": "So",
              "highlight": true
            },
            {
              "text": " and ",
              "highlight": true
            },
            {
              "text": "Neither",
              "highlight": true
            },
            {
              "text": " - Showing Agreement"
            },
            {
              "text": "So و Neither - إظهار الموافقة"
            }
          ]
        },
        {
          "id": "card-18",
          "content": [
            {
              "text": "Both express "
            },
            {
              "text": "agreement",
              "colorize2": true
            },
            {
              "text": " with what someone said"
            },
            {
              "text": "كلاهما يعبر عن "
            },
            {
              "text": "الموافقة",
              "colorize2": true
            },
            {
              "text": " مع ما قاله شخص ما"
            }
          ]
        }
      ]
    },
    {
